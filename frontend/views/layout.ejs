<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="bi bi-heart-pulse-fill me-2"></i>Здоровье+</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Главная</a></li>
                    <li class="nav-item"><a class="nav-link" href="/medicines">Каталог</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/chat"><i class="bi bi-chat-dots-fill me-1"></i>Чат поддержки</a></li>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item"><a class="nav-link text-warning fw-bold" href="/medicines/create"><i class="bi bi-truck me-1"></i>Новая поставка</a></li>
                        <% } %>
                    <% } %>
                </ul>
                <ul class="navbar-nav">
                    <% if (user) { %>
                        <li class="nav-item">
                            <span class="nav-link text-light"><i class="bi bi-person-circle me-1"></i><%= user.username %> (<%= user.role === 'admin' ? 'Admin' : 'Пользователь' %>)</span>
                        </li>
                        <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm ms-2" href="/logout">Выйти</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right me-1"></i>Вход</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register"><i class="bi bi-person-plus me-1"></i>Регистрация</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <main class="container mt-5 flex-grow-1">
        <%- include(bodyView) %>
    </main>
    <footer class="bg-dark text-light py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 Аптека "Здоровье+". Все права защищены.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>