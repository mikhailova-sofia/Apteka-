<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Редактировать препарат</h4>
            </div>
            <div class="card-body p-4">
                <% if (error) { %>
                    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
                <% } %>
                <form action="/medicines/<%= medicine.id %>/update" method="POST">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Название *</label>
                            <input type="text" name="name" class="form-control" value="<%= medicine.name || '' %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">URL картинки</label>
                            <input type="url" name="imageUrl" class="form-control" value="<%= medicine.imageUrl || '' %>">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Описание</label>
                        <textarea name="description" class="form-control" rows="3"><%= medicine.description || '' %></textarea>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Цена (₽) *</label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="price" class="form-control" value="<%= medicine.price || '' %>" required>
                                <span class="input-group-text">₽</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Количество *</label>
                            <input type="number" name="quantity" class="form-control" value="<%= medicine.quantity || '' %>" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Дата поступления</label>
                            <input type="date" name="arrivalDate" class="form-control" value="<%= medicine.arrivalDate || '' %>">
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-1"></i>Обновить</button>
                        <a href="/medicines" class="btn btn-light border"><i class="bi bi-x-lg me-1"></i>Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>