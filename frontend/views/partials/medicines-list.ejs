<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-success"><i class="bi bi-box2-heart me-2"></i>Каталог препаратов</h2>
    <% if (user && user.role === 'admin') { %>
        <a href="/medicines/create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i>Добавить препарат</a>
    <% } %>
</div>

<% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i><%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<form class="mb-5" action="/medicines" method="GET">
    <div class="input-group input-group-lg shadow-sm">
        <span class="input-group-text bg-white border-end-0 text-success"><i class="bi bi-search"></i></span>
        <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Умный поиск по названию или описанию..." value="<%= search %>">
        <button class="btn btn-success px-4" type="submit">Найти</button>
        <% if (search) { %>
            <a href="/medicines" class="btn btn-outline-secondary px-4">Сбросить</a>
        <% } %>
    </div>
</form>

<% if (medicines.length === 0) { %>
    <div class="alert alert-info border-0 shadow-sm">
        <i class="bi bi-info-circle-fill me-2"></i>По вашему запросу ничего не найдено.
    </div>
<% } else { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% medicines.forEach(m => { %>
            <div class="col">
                <div class="card h-100 shadow-sm border-0 medicine-card">
                    <% if (m.imageUrl) { %>
                        <img src="<%= m.imageUrl %>" class="card-img-top object-fit-cover" alt="<%= m.name %>" style="height: 200px;">
                    <% } else { %>
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height: 200px;">
                            <i class="bi bi-image display-4"></i>
                        </div>
                    <% } %>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0 text-dark"><%= m.name %></h5>
                            <span class="badge bg-success rounded-pill fs-6"><%= m.price %> ₽</span>
                        </div>
                        <p class="card-text text-muted small flex-grow-1"><%= m.description || 'Описание отсутствует' %></p>
                        
                        <div class="d-flex justify-content-between align-items-center mb-3 text-secondary small">
                            <span><i class="bi bi-box-seam me-1"></i>Остаток: <%= m.quantity %> шт.</span>
                            <% if (m.arrivalDate) { %>
                                <span class="text-success" title="Дата поступления"><i class="bi bi-truck me-1"></i><%= m.arrivalDate %></span>
                            <% } %>
                        </div>
                        
                        <% if (user && user.role === 'admin') { %>
                            <div class="mt-auto pt-3 border-top">
                                <a href="/medicines/<%= m.id %>/edit" class="btn btn-outline-primary btn-sm w-100 mb-2"><i class="bi bi-pencil me-1"></i>Редактировать</a>
                                <button class="btn btn-outline-danger btn-sm w-100" onclick="deleteMedicine(<%= m.id %>)"><i class="bi bi-trash me-1"></i>Удалить</button>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>